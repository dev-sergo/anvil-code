# ============================================================
# RAG System — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# -------------------------------------------------------
# LLM Backend
# -------------------------------------------------------
# Which backend to use for chat completions:
#   llamacpp — OpenAI-compatible /v1/chat/completions (llama-swap proxy or bare llama-server). RECOMMENDED.
#   ollama   — legacy /api/chat, kept as fallback for users without llama-swap.
LLM_BACKEND=llamacpp

# Optional override for embedding backend; mirrors LLM_BACKEND when empty.
# Set to 'ollama' for hybrid mode (chat→llamacpp, embed→ollama).
EMBED_BACKEND=

# -------------------------------------------------------
# llama.cpp / llama-swap (used when LLM_BACKEND=llamacpp)
# -------------------------------------------------------
# Single endpoint that fronts all model aliases. llama-swap auto-loads/unloads
# models in VRAM on demand based on the `model` field of the request.
LLM_URL=http://localhost:8080

# Model alias for code-producing roles (coder/fixer/architect).
# Should match an alias declared in your llama-swap config.yaml.
# 'gemma' (gemma-4-26b-a4b ctx-32k) — validated default since v1.35 (7/8 on L2.x bench).
# Alternatives: 'qwen-coder-long' (qwen2.5-coder-32b ctx-16k), 'deepseek' (deepseek-coder-33b).
LLM_LARGE_MODEL=qwen3-32k

# Optional alias with longer context for refactor / scale tasks. Same as large if unset.
LLM_LARGE_LONG_MODEL=gemma

# Model alias for fast/judging roles (planner/reviewer/tester).
# 'qwen3' (qwen3.6-35B-A3B MoE, 3B active) — fastest, good for routing/judging.
LLM_SMALL_MODEL=qwen3-32k

# Embedding model alias. Must be exposed via /v1/embeddings on the same endpoint.
# nomic-embed-text-v1.5: 768 dim, requires search_query: / search_document: prefixes
# (wired automatically in packages/rag/).
LLM_EMBED_MODEL=embed

# Cross-encoder reranker alias (used when RAG_RERANKER_ENABLED=true).
LLM_RERANK_MODEL=reranker

# -------------------------------------------------------
# Ollama (legacy fallback; used when LLM_BACKEND=ollama)
# -------------------------------------------------------
# Base URL of the running Ollama instance.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model used for complex coding tasks (architect, coder, fixer agents).
OLLAMA_MODEL_LARGE=deepseek-coder-v2:16b

# Model used for fast tasks (planner, reviewer, tester agents).
OLLAMA_MODEL_SMALL=qwen2.5-coder:7b

# Model used for text embeddings (RAG vector indexing).
OLLAMA_EMBED_MODEL=nomic-embed-text

# -------------------------------------------------------
# API Server
# -------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# -------------------------------------------------------
# Target Project (the codebase the system works on)
# -------------------------------------------------------
# Absolute path to the git repository the system will analyze and modify.
# If not set, defaults to process.cwd(). Override per-task via the /task endpoint.
PROJECT_ROOT=

# -------------------------------------------------------
# Memory & Storage
# -------------------------------------------------------
# Root directory for all runtime data (memory.db, projects.db, vectors, graphs,
# backups). Relative to project root unless absolute.
DATA_ROOT=data

# Path to SQLite database file holding agent memory.
MEMORY_DB_PATH=data/memory.db

# -------------------------------------------------------
# Project Registry
# -------------------------------------------------------
# SQLite registry of indexed projects (paths, branches, last-indexed timestamp).
PROJECT_REGISTRY_PATH=data/projects.db

# When true, the API auto-registers PROJECT_ROOT on first /task if it is missing
# from the registry. Disable to require explicit POST /projects calls.
PROJECTS_AUTO_REGISTER_DEFAULT=true

# -------------------------------------------------------
# Code Graph (AST index)
# -------------------------------------------------------
# Comma-separated glob patterns for files to include in AST indexing.
CODE_GRAPH_INCLUDE=**/*.ts,**/*.js,**/*.tsx,**/*.jsx,**/*.py,**/*.rs,**/*.go

# Comma-separated directories to exclude.
CODE_GRAPH_EXCLUDE=node_modules,dist,.git,coverage

# -------------------------------------------------------
# RAG (vector retrieval)
# -------------------------------------------------------
# Embedding vector dimension (768 for nomic-embed-text).
EMBEDDING_DIM=768

# Maximum number of vectors in the HNSW index before auto-resize.
VECTOR_MAX_ELEMENTS=10000

# Maximum context tokens to pass to agents from retrieved chunks.
# 1500 — tuned default; keeps prompt fit on 8K-16K ctx models with room for
# tool-calling history. Raise to 3000-8000 only if your Large model has 32K+ ctx
# and you are seeing under-retrieval on complex tasks.
RAG_MAX_CONTEXT_TOKENS=1500

# Where the HNSW vector index files live.
VECTORS_PATH=data/vectors

# Where the AST graph index files live.
GRAPHS_PATH=data/graphs

# v1.34 hybrid retrieval — BM25 lexical search blended with vector recall via RRF.
# Enabled by default; disable to fall back to pure vector search.
RAG_BM25_ENABLED=true
RAG_BM25_CANDIDATES=30

# Cross-encoder reranking (uses LLM_RERANK_MODEL). Off by default — enable for
# quality-over-latency runs; pulls RAG_RERANKER_CANDIDATES top hits and re-scores.
RAG_RERANKER_ENABLED=false
RAG_RERANKER_CANDIDATES=30

# Concurrency knobs for indexing. Lower if your llama-swap is saturating.
EMBED_CONCURRENCY=8
FILE_CONCURRENCY=4

# -------------------------------------------------------
# File Watcher (incremental re-indexing)
# -------------------------------------------------------
# Off by default. Enable to re-index changed files automatically while the
# API server is running.
WATCH_ENABLED=false
WATCH_DEBOUNCE_MS=1500

# -------------------------------------------------------
# Job System
# -------------------------------------------------------
# Maximum retry attempts for failed jobs.
JOB_MAX_RETRIES=3

# Polling interval in milliseconds for the worker loop.
JOB_POLL_INTERVAL_MS=1000

# -------------------------------------------------------
# Safe Execution & Backups
# -------------------------------------------------------
# Globally short-circuit all file writes (dry-run). Useful for debug runs.
SAFE_EXEC_DRY_RUN=false

# Back up each file before overwrite so a failed edit can be rolled back.
SAFE_EXEC_BACKUP=true

# Where backups live, and how long they are retained.
BACKUPS_PATH=data/backups
BACKUP_MAX_AGE_DAYS=7
BACKUP_PRUNE_INTERVAL_HOURS=24

# -------------------------------------------------------
# Git
# -------------------------------------------------------
# Default branch name used as base for new task branches.
GIT_DEFAULT_BRANCH=main

# Prefix for auto-created branches.
GIT_BRANCH_PREFIX=auto/task

# Skip commit when validation fails after Fixer retries are exhausted.
# With =true (default), an auto-branch is created but left uncommitted on
# validation failure — protects main-ward flows from broken code. Set =false
# to keep the legacy behavior of always committing (useful for debugging).
COMMIT_ONLY_IF_VALID=true

# v1.39-a — cumulative mode. When true, each successful task ff-merges its
# auto-branch into CUMULATIVE_BRANCH so the next task forks from accumulated
# state instead of GIT_DEFAULT_BRANCH. Main stays untouched. On non-ff merge,
# the orchestrator emits `cumulative_merge_failed` and leaves the task branch
# intact for manual review. Default false — safe for production repos.
CUMULATIVE_MODE=false
CUMULATIVE_BRANCH=auto/cumulative

# -------------------------------------------------------
# Agents
# -------------------------------------------------------
# Run TesterAgent after Coder. Set =false to skip test generation entirely —
# useful when iterating on Coder quality without Tester noise, or when the
# project's test conventions confuse the model.
TESTER_ENABLED=true

# Hard cap on Planner output. Any extra steps are truncated (with dangling deps
# stripped). Default 50 = effectively unlimited. Lower for smoke tests where you
# want a single Coder pass: e.g. PLANNER_MAX_STEPS=1 forces atomic execution.
PLANNER_MAX_STEPS=50

# Max number of agents the orchestrator runs in parallel for a single task.
AGENTS_PARALLELISM=3

# When true, the Orchestrator uses the tool-calling Coder
# (read_file/replace_in_file/create_file/delete_file/done) instead of the
# patch-based Coder. Default true since v1.32-d Phase F: tool-calling is the
# validated structural-anchors path required for non-trivial tasks.
# Set to false only for regression-debug. Since v1.39-c this also drives the
# step-level Reviewer-reject path (BUGFIX_SPEC vs patch-based Fixer).
TOOL_CALLING_CODER=true

# v1.39-b — per-attempt timeout (ms) for runValidationLoop (tsc + tests).
# On timeout the orchestrator emits validation_fail with reason='timeout_or_crash'
# so the task always reaches a terminal validation event after validation_start
# (closes T3 `validation_incomplete` from v1.38 real-repo bench).
VALIDATION_TIMEOUT_MS=300000

# v1.46 — depth of the reverse-dependency BFS in retrieveContextItems.
# 1 = direct callers only (default, validated at 11/12 on real repos).
# 2-3 = callers-of-callers — useful for cross-service refactoring where you
# need all callsites, but increases noise in dense monorepos (trpc 3938
# symbols: hops=3 caused 11→9/12 regression). Raise only for explicit
# cross-service tasks. Capped at 4.
RAG_GRAPH_HOPS=1
RAG_CALLERS_PER_SYMBOL=3

# v1.47 — vector backend. 'hnsw' (default) uses the local hnswlib-node index.
# 'qdrant' routes through a Qdrant server — requires docker run first:
#   docker run -d --name qdrant -p 6333:6333 qdrant/qdrant
# Benefits: no 10K cap, persistent storage, payload-filtered retrieval.
VECTOR_BACKEND=hnsw
QDRANT_URL=http://localhost:6333
