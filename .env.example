# ============================================================
# RAG System — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# -------------------------------------------------------
# LLM Backend (v1.32-d)
# -------------------------------------------------------
# Which backend to use for chat completions:
#   ollama   — legacy /api/chat, kept as fallback
#   llamacpp — OpenAI-compatible /v1/chat/completions (llama-swap proxy or bare llama-server)
# Default 'ollama' until v1.32-d Phase E (bench validation) flips it to 'llamacpp'.
LLM_BACKEND=ollama

# Optional override for embedding backend; mirrors LLM_BACKEND when empty.
# Set to 'ollama' for hybrid mode (chat→llamacpp, embed→ollama).
EMBED_BACKEND=

# -------------------------------------------------------
# llama.cpp / llama-swap (used when LLM_BACKEND=llamacpp)
# -------------------------------------------------------
# Single endpoint that fronts all model aliases. llama-swap auto-loads/unloads
# models in VRAM on demand by the `model` field of the request.
LLM_URL=http://localhost:8080

# Model alias for code-producing roles (coder/fixer/architect).
# Should match an alias declared in your llama-swap config.yaml.
LLM_LARGE_MODEL=coder

# Optional alias with longer context (16K) for refactor / scale tasks.
LLM_LARGE_LONG_MODEL=qwen-coder-long

# Model alias for fast/judging roles (planner/reviewer/tester).
LLM_SMALL_MODEL=qwen3

# Embedding model alias. Must be a model exposed via /v1/embeddings.
# nomic-embed-text-v1.5: 768 dim, requires search_query: / search_document: prefixes
# (wired automatically in packages/rag/).
LLM_EMBED_MODEL=embed

# -------------------------------------------------------
# Ollama (legacy fallback; used when LLM_BACKEND=ollama)
# -------------------------------------------------------
# Base URL of the running Ollama instance
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model used for complex coding tasks (architect, coder, fixer agents)
OLLAMA_MODEL_LARGE=deepseek-coder-v2:16b

# Model used for fast tasks (planner, reviewer, tester agents)
OLLAMA_MODEL_SMALL=qwen2.5-coder:7b

# Model used for text embeddings (RAG vector indexing)
OLLAMA_EMBED_MODEL=nomic-embed-text

# -------------------------------------------------------
# API Server
# -------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# -------------------------------------------------------
# Target Project (the codebase the system works on)
# -------------------------------------------------------
# Absolute path to the git repository the system will analyze and modify.
# If not set, defaults to process.cwd().
PROJECT_ROOT=

# -------------------------------------------------------
# Memory & Storage
# -------------------------------------------------------
# Path to SQLite database file (relative to project root or absolute)
MEMORY_DB_PATH=data/memory.db

# -------------------------------------------------------
# Code Graph
# -------------------------------------------------------
# Comma-separated glob patterns for files to include in AST indexing
CODE_GRAPH_INCLUDE=**/*.ts,**/*.js,**/*.tsx,**/*.jsx

# Comma-separated glob patterns for directories to exclude
CODE_GRAPH_EXCLUDE=node_modules,dist,.git,coverage

# -------------------------------------------------------
# RAG
# -------------------------------------------------------
# Embedding vector dimension (768 for nomic-embed-text)
EMBEDDING_DIM=768

# Maximum number of vectors in the HNSW index before auto-resize
VECTOR_MAX_ELEMENTS=10000

# Maximum context tokens to pass to agents
RAG_MAX_CONTEXT_TOKENS=8000

# -------------------------------------------------------
# Job System
# -------------------------------------------------------
# Maximum retry attempts for failed jobs
JOB_MAX_RETRIES=3

# Polling interval in milliseconds for the worker loop
JOB_POLL_INTERVAL_MS=1000

# -------------------------------------------------------
# Safe Execution
# -------------------------------------------------------
# Enable dry-run mode globally (no actual file writes)
SAFE_EXEC_DRY_RUN=false

# Enable file backup before overwrite
SAFE_EXEC_BACKUP=true

# -------------------------------------------------------
# Git
# -------------------------------------------------------
# Default branch name to use as base for new task branches
GIT_DEFAULT_BRANCH=main

# Prefix for auto-created branches
GIT_BRANCH_PREFIX=auto/task

# Skip commit when validation fails after Fixer retries are exhausted.
# With =true (default), an auto-branch is created but left uncommitted on
# validation failure — protects main-ward flows from broken code. Set =false
# to keep the legacy behavior of always committing (useful for debugging).
COMMIT_ONLY_IF_VALID=true

# Run TesterAgent after Coder. Set =false to skip test generation entirely —
# useful when iterating on Coder quality without Tester noise, or when the
# project's test conventions confuse the model.
TESTER_ENABLED=true

# Hard cap on Planner output. Any extra steps are truncated (with dangling deps
# stripped). Default 50 = effectively unlimited. Lower for smoke tests where you
# want a single Coder pass: e.g. PLANNER_MAX_STEPS=1 forces atomic execution.
PLANNER_MAX_STEPS=50
