# ============================================================
# RAG System — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# -------------------------------------------------------
# Ollama LLM Backend
# -------------------------------------------------------
# Base URL of the running Ollama instance
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model used for complex coding tasks (architect, coder, fixer agents)
OLLAMA_MODEL_LARGE=deepseek-coder-v2:16b

# Model used for fast tasks (planner, reviewer, tester agents)
OLLAMA_MODEL_SMALL=qwen2.5-coder:7b

# Model used for text embeddings (RAG vector indexing)
OLLAMA_EMBED_MODEL=nomic-embed-text

# -------------------------------------------------------
# API Server
# -------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# -------------------------------------------------------
# Target Project (the codebase the system works on)
# -------------------------------------------------------
# Absolute path to the git repository the system will analyze and modify.
# If not set, defaults to process.cwd().
PROJECT_ROOT=

# -------------------------------------------------------
# Memory & Storage
# -------------------------------------------------------
# Path to SQLite database file (relative to project root or absolute)
MEMORY_DB_PATH=data/memory.db

# -------------------------------------------------------
# Code Graph
# -------------------------------------------------------
# Comma-separated glob patterns for files to include in AST indexing
CODE_GRAPH_INCLUDE=**/*.ts,**/*.js,**/*.tsx,**/*.jsx

# Comma-separated glob patterns for directories to exclude
CODE_GRAPH_EXCLUDE=node_modules,dist,.git,coverage

# -------------------------------------------------------
# RAG
# -------------------------------------------------------
# Embedding vector dimension (768 for nomic-embed-text)
EMBEDDING_DIM=768

# Maximum number of vectors in the HNSW index before auto-resize
VECTOR_MAX_ELEMENTS=10000

# Maximum context tokens to pass to agents
RAG_MAX_CONTEXT_TOKENS=8000

# -------------------------------------------------------
# Job System
# -------------------------------------------------------
# Maximum retry attempts for failed jobs
JOB_MAX_RETRIES=3

# Polling interval in milliseconds for the worker loop
JOB_POLL_INTERVAL_MS=1000

# -------------------------------------------------------
# Safe Execution
# -------------------------------------------------------
# Enable dry-run mode globally (no actual file writes)
SAFE_EXEC_DRY_RUN=false

# Enable file backup before overwrite
SAFE_EXEC_BACKUP=true

# -------------------------------------------------------
# Git
# -------------------------------------------------------
# Default branch name to use as base for new task branches
GIT_DEFAULT_BRANCH=main

# Prefix for auto-created branches
GIT_BRANCH_PREFIX=auto/task
